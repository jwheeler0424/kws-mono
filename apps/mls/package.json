{
  "name": "mls",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun --bun run src/index.ts",
    "build": "bun --bun build src/index.ts --outdir dist --target bun",
    "start": "bun --bun run dist/index.js",
    "history:verify": "bun --bun run src/index.ts history:verify",
    "history:compact": "bun --bun run src/index.ts history:compact",
    "history:recover": "bun --bun run src/index.ts history:recover",
    "history:quarantine-summary": "bun --bun run src/index.ts history:quarantine-summary",
    "history:storage-report": "bun --bun run src/index.ts history:storage-report",
    "benchmark:delta": "bun --bun run src/index.ts benchmark:delta",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@kws/config": "*",
    "@kws/logger": "*",
    "@kws/media": "*",
    "@kws/schema": "*",
    "@tanstack/pacer": "^0.21.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^1.0.0-rc.4-5d5b77c",
    "h3-js": "^4.4.0",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@kws/types": "*",
    "@kws/typescript": "*",
    "@kws/utils": "*",
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^1.0.0-rc.4-ca0f029",
    "esbuild": "^0.28.1"
  },
  "peerDependencies": {
    "typescript": "^7"
  }
}
