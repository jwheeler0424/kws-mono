{
  "extends": "@kws/typescript/react-library.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "dist",
    // Environment setup & latest features
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
    },
  },
  "types": [
    "bun",
    "node",
    "react",
    "react-dom",
    "vite/client"
  ],
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}