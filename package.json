{
  "name": "kws-mono",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev:up": "docker compose --env-file packages/config/.env -f docker-compose.dev.yml up -d --build --remove-orphans",
    "dev:down": "docker compose --env-file packages/config/.env -f docker-compose.dev.yml down --remove-orphans --volumes --rmi local",
    "prod:up": "docker compose --env-file packages/config/.env -f docker-compose.prod.yml up -d --remove-orphans && docker compose --env-file packages/config/.env -f docker-compose.prod.yml rm -f migrate || true",
    "prod:down": "docker compose --env-file packages/config/.env -f docker-compose.prod.yml down --remove-orphans --volumes --rmi local",
    "prod:local:up": "docker compose --env-file .env.local.prod -f docker-compose.prod.yml -f docker-compose.prod.local.yml up -d --remove-orphans db redis app_blue app_green mls nginx && docker compose --env-file .env.local.prod -f docker-compose.prod.yml -f docker-compose.prod.local.yml rm -f migrate || true",
    "prod:local:down": "docker compose --env-file .env.local.prod -f docker-compose.prod.yml -f docker-compose.prod.local.yml down --remove-orphans",
    "prod:local:ps": "docker compose --env-file .env.local.prod -f docker-compose.prod.yml -f docker-compose.prod.local.yml ps",
    "swarm:local:up": "RUN_MIGRATIONS=1 bash scripts/swarm-local-deploy.sh",
    "swarm:local:update": "RUN_MIGRATIONS=1 bash scripts/swarm-local-deploy.sh",
    "swarm:local:up:no-migrate": "RUN_MIGRATIONS=0 bash scripts/swarm-local-deploy.sh",
    "swarm:local:up:pull": "PULL_IMAGES=1 RUN_MIGRATIONS=1 bash scripts/swarm-local-deploy.sh",
    "swarm:local:up:pull:no-migrate": "PULL_IMAGES=1 RUN_MIGRATIONS=0 bash scripts/swarm-local-deploy.sh",
    "swarm:local:down": "bash scripts/swarm-local-down.sh",
    "swarm:local:ps": "docker service ls --filter label=com.docker.stack.namespace=${STACK_NAME:-kws}",
    "build": "turbo run build",
    "deploy:images": "bash scripts/deploy-images.sh",
    "deploy:project": "RUN_MIGRATIONS=1 bash scripts/deploy-project.sh",
    "deploy:project:no-migrate": "RUN_MIGRATIONS=0 bash scripts/deploy-project.sh",
    "dev": "turbo run dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write .",
    "check": "oxfmt --check . && oxlint --fix",
    "check:types": "turbo run check-types",
    "db:fresh": "cd packages/schema && bun run db:fresh",
    "db:push": "cd packages/schema && bun run db:push",
    "db:pull": "cd packages/schema && bun run db:pull",
    "db:reset": "cd packages/schema && bun run db:reset",
    "db:studio": "cd packages/schema && bun run db:studio",
    "db:generate": "cd packages/schema && bun run db:generate",
    "db:migrate": "cd packages/schema && bun run db:migrate"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "turbo": "2.10.5",
    "typescript": "^7.0.2"
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=26.0.0"
  },
  "packageManager": "bun@1.3.14"
}
