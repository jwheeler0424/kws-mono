{
  "name": "kws-mono",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev:up": "docker compose --env-file packages/config/.env -f docker-compose.dev.yml up -d --build --remove-orphans",
    "dev:down": "docker compose --env-file packages/config/.env -f docker-compose.dev.yml down --remove-orphans --volumes --rmi local",
    "prod:up": "docker compose --env-file packages/config/.env -f docker-compose.prod.yml up -d --build --remove-orphans",
    "prod:down": "docker compose --env-file packages/config/.env -f docker-compose.prod.yml down --remove-orphans --volumes --rmi local",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write .",
    "check": "oxfmt --check . && oxlint --fix",
    "check:types": "turbo run check-types",
    "db:fresh": "cd packages/schema && bun run db:fresh",
    "db:push": "cd packages/schema && bun run db:push",
    "db:pull": "cd packages/schema && bun run db:pull",
    "db:reset": "cd packages/schema && bun run db:reset",
    "db:studio": "cd packages/schema && bun run db:studio",
    "db:generate": "cd packages/schema && bun run db:generate",
    "db:migrate": "cd packages/schema && bun run db:migrate"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "turbo": "^2.10.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=26.0.0"
  },
  "packageManager": "bun@1.3.14"
}
