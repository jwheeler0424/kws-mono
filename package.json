{
  "name": "kws-mono",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:up": "docker compose -f docker-compose.dev.yml up -d --build --remove-orphans",
    "dev:down": "docker compose -f docker-compose.dev.yml down --remove-orphans --volumes --rmi local",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write .",
    "check": "oxfmt --check . && oxlint --fix",
    "check:types": "turbo run check-types"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=26.0.0"
  },
  "packageManager": "bun@1.3.14"
}
