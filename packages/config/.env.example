# ── Environment ──────────────────────────────────────────────────────────────
NODE_ENV="development"
HOST="localhost"
PORT=3443

# ── Logging configuration ────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true
LOG_REDACT_KEYS=''

# ── Application configuration ────────────────────────────────────────────────
APP_NAME="KyleWeberSeattle.com"
APP_URL=http://${HOST}:${PORT}

# ── Database configuration ───────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DATABASE_URL=postgres://$DB_USER:$DB_PASSWORD@$DB_HOST:$DB_PORT/$DB_NAME

# ── Redis configuration ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://$REDIS_HOST:$REDIS_PORT

# ── Ollama configuration ─────────────────────────────────────────────────────
OLLAMA_MODEL=qwen3.5:2b
OLLAMA_PORT=11434
OLLAMA_HOST=192.168.1.118
OLLAMA_BASE_URL=http://$OLLAMA_HOST:$OLLAMA_PORT
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=256
OLLAMA_KEEP_ALIVE=5m

# ── BetterAuth configuration ─────────────────────────────────────────────────
BETTER_AUTH_SECRET=SuperSecretKeyThatShouldBeChangedInProduction

# ── Email configuration ─────────────────────────────────────────────────────
EMAIL_DOMAIN=kyleweberseattle.com
EMAIL_FROM="$APP_NAME <auto@$EMAIL_DOMAIN>"

# ── SMTP transport ───────────────────────────────────────────────────────────
SMTP_HOST=mail.$EMAIL_DOMAIN
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=auto@$EMAIL_DOMAIN
SMTP_PASS=SuperSecretPasswordThatShouldBeChangedInProduction

# ── IMAP incoming (optional, defaults to SMTP values when omitted) ───────────
IMAP_HOST=mail.$EMAIL_DOMAIN
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=auto@$EMAIL_DOMAIN
IMAP_PASS=SuperSecretPasswordThatShouldBeChangedInProduction

# ── DKIM optional unless required by your provider/policy ────────────────────
DKIM_DOMAIN=$EMAIL_DOMAIN
DKIM_SELECTOR=dkim
DKIM_PRIVATE_KEY=SUPER_SECRET_DKIM_PRIVATE_KEY_THAT_SHOULD_BE_CHANGED_IN_PRODUCTION

# ── Pulse email + analytics ──────────────────────────────────────────────────
TRACKING_HOST=$HOST
TRACKING_PORT=$PORT
TRACKING_DOMAIN=http://$TRACKING_HOST:$TRACKING_PORT
TRACKING_FALLBACK_URL=http://$TRACKING_HOST:$TRACKING_PORT
BOUNCE_DOMAIN=bounce.$EMAIL_DOMAIN

# ── Pulse runtime ────────────────────────────────────────────────────────────
EMAIL_TOKEN_TTL_DAYS=90

# ── MLS configuration ────────────────────────────────────────────────────────
# -- Test Credentials -- #
# MLS_ACCESS_KEY=SUPER_SECRET_PRIVATE_KEY_THAT_SHOULD_BE_CHANGED_IN_PRODUCTION
# MLS_API_URL=https://api-demo.mlsgrid.com/v2/

# -- MLS Credentials -- #
# MLS_ORIGINATING_SYSTEM_NAME=nwmls
# MLS_OFFICE_ID=NWM5617
# MLS_MEMBER_ID=NWM108866,NWM31726,NWM49329,NWM51793,NWM70782

# -- Live Credentials -- #
MLS_ACCESS_KEY=SUPER_SECRET_PRIVATE_KEY_THAT_SHOULD_BE_CHANGED_IN_PRODUCTION
MLS_API_URL=https://api.mlsgrid.com/v2/

# -- MLS Credentials -- #
MLS_ORIGINATING_SYSTEM_NAME=nwmls
# MLS_OFFICE_ID=NWM5617
MLS_MEMBER_ID=NWM133212,NWM43894,NWM144725,NWM147491,NWM41998
MLS_RESOURCE_EXPAND=Property:Media,Property:Rooms,Property:UnitTypes,Member:Media,Office:Media
MLS_START_DATE="2025-01-01T00:00:00.000Z" # Start Data: 1/1/2025

# -- MLS sync config (preferred keys) -- #
MLS_PAGE_SIZE="5000"
MLS_MAX_PAGE_SIZE_WITH_EXPAND="1000"
MLS_REQUEST_DELAY_MS="550"
MLS_REQUESTS_PER_SECOND="2"
MLS_REQUEST_THROTTLE_CURVE_POWER="4"
MLS_REQUEST_THROTTLE_MAX_DELAY_MS="5000"
MLS_DELTA_OVERLAP_MS="0"
MLS_MIN_DELTA_OVERLAP_MS="1000"
MLS_TIMESTAMP_PRECISION_SAFETY_MS="1000"
MLS_REQUESTS_PER_HOUR_LIMIT="7200"
MLS_REQUESTS_PER_DAY_LIMIT="40000"
MLS_BYTES_PER_HOUR_LIMIT="3221225472"
MLS_BYTES_PER_DAY_LIMIT="64424509440"
MLS_QUOTA_WARN_THRESHOLD_RATIO="0.9"
MLS_QUOTA_STATE_FILE=".mls-quota-state.json"
MLS_HISTORY_STORE_ENABLED="true"
MLS_HISTORY_STORE_PATH="data"
MLS_HISTORY_REPLAY_BATCH_SIZE="500"
MLS_HISTORY_LOCK_TIMEOUT_MS="30000"
MLS_HISTORY_LOCK_STALE_MS="300000"
MLS_HISTORY_COMPACT_MAX_BYTES="268435456"
MLS_HISTORY_VERIFY_CHECKSUM_ENABLED="true"
MLS_HISTORY_QUARANTINE_ENABLED="true"
MLS_TIMESTAMP_QUARANTINE_ALERT_THRESHOLD="1"
MLS_PROPERTY_BATCH_SIZE="100"
MLS_PROPERTY_UPSERT_BATCH_SIZE="150"
MLS_PROPERTY_CHILD_UPSERT_BATCH_SIZE="750"
MLS_PROPERTY_CHILD_UPSERT_CONCURRENCY="2"
MLS_PROPERTY_SEED_USE_STAGING="false"
MLS_PROPERTY_SEED_STAGING_SYNC_COMMIT_OFF="false"
MLS_PROPERTY_SEED_STAGING_STATEMENT_TIMEOUT_MS="120000"
MLS_PROPERTY_SEED_STAGING_LOCK_TIMEOUT_MS="5000"
MLS_PROPERTY_SEED_STAGING_WORK_MEM_MB="128"
MLS_PROPERTY_SEED_STAGING_JIT_OFF="true"
MLS_SEED_FETCH_INGEST_OVERLAP_ENABLED="true"
MLS_SEED_FETCH_INGEST_QUEUE_DEPTH="2"
MLS_SEED_PREFETCH_ENABLED="true"
MLS_CLEANUP_RETENTION_DAYS="30"

# -- MLS Scheduler config -- #
MLS_QUEUE_ENABLE_HOURLY_SYNC="true"
MLS_QUEUE_RESOURCE_CRON_SCHEDULES="Lookup:1,16,31,46 * * * *;Property:4,19,34,49 * * * *;Office:7,22,37,52 * * * *;Member:10,25,40,55 * * * *;OpenHouse:13,28,43,58 * * * *"
MLS_QUEUE_INITIAL_STRICT_SUCCESS="false"
MLS_QUEUE_ENABLE_CLEANUP="true"
MLS_QUEUE_CLEANUP_CRON="2 * * * *"
MLS_QUEUE_OPENHOUSE_RECONCILIATION_CRON="14,29,44,59 * * * *"
MLS_QUEUE_MEDIA_SYNC_CRON="*/30 * * * *"
MLS_QUEUE_MEDIA_SYNC_BATCH_SIZE="16"
MLS_QUEUE_MEDIA_SYNC_MAX_BATCHES="24"
MLS_QUEUE_MEDIA_SYNC_PROCESS_CONCURRENCY="2"
MLS_QUEUE_MEDIA_SYNC_JOB_CONCURRENCY="1"
MLS_QUEUE_MAX_CONCURRENT_SCHEDULED_JOBS="1"
MLS_QUEUE_MEDIA_SYNC_INCLUDE_MISSING_FILES_REPAIR="false"
MLS_QUEUE_MEDIA_SYNC_REPAIR_MAX_BATCHES="2"
MLS_QUEUE_MEDIA_RECONCILE_CRON="0 */6 * * *"
MLS_ROLLOUT_ENABLE_INITIAL_DATA_SEED="true"
MLS_ROLLOUT_ENABLE_INITIAL_MEDIA_SEED="true"
MLS_ROLLOUT_ENABLE_SYNC_JOB_REGISTRATION="true"

# ── Alerting and monitoring ─────────────────────────────────────────────────
  ALERT_SERVICE_NAME=
  ALERT_WEBHOOK_URL=
  ALERT_WEBHOOK_SECRET=
  ALERT_DLQ_THRESHOLD=5
  ALERT_WEBHOOK_TIMEOUT_MS=5000

# ── Queue retention cleanup ───────────────────────────────────────────────
  QUEUE_RETENTION_ENABLE_AUTOCLEANUP=true
  QUEUE_RETENTION_CLEANUP_INTERVAL_MS=3600000
  QUEUE_RETENTION_IDEMPOTENCY_HOURS=48
  QUEUE_RETENTION_DEADLETTER_HOURS=168
  QUEUE_RETENTION_JOB_RUNS_HOURS=168